---
import SiteLayout from "../../layouts/SiteLayout.astro";

const capabilities = [
  ["Directos organizados por canciones", "Organiza el concierto como canciones con sus propias regiones, clips, tempo, nivel principal, marcas y paquetes reutilizables."],
  ["Control musical en vivo", "Usa saltos de marca, saltos de cancion, bucles Vamp, modos de transicion, atajos y mapeos MIDI desde una superficie enfocada."],
  ["Tono y tempo", "Transpone canciones, ajusta el audio al tempo del timeline con Warp y decide que pistas siguen el cambio de tono con el control T por pista."],
  ["Ruteo y control remoto", "Envia pistas, click, cues, guias y buses de carpeta a las salidas correctas, y controla transporte o mezcla desde movil/tablet."],
];

const workflow = [
  ["Construye la biblioteca", "Importa WAVs preparados, organiza recursos en carpetas virtuales y reutiliza canciones con paquetes LibreTracks.", "/screenshots/Library-Assets-Import.gif"],
  ["Da forma al repertorio", "Organiza clips en un timeline musical, crea regiones de cancion, colorea sesiones densas y coloca marcas donde ocurren las decisiones en vivo.", "/screenshots/Proyecto.png"],
  ["Ensaya y toca", "Cambia a Vista Compacta para ver una columna por cancion, ajustar la mezcla compartida, disparar canciones y leer el repertorio bajo presion.", "/screenshots/Compact-View.png"],
];

const viewHighlights = [
  ["Timeline lineal", "Una vista tipo DAW para organizar pistas, editar clips, revisar marcas y preparar la estructura del concierto."],
  ["Vista Compacta", "Una vista orientada a canciones para ensayo y directo, con columnas, controles de reproduccion, faders master y mezclador compartido."],
  ["Un unico proyecto", "Las dos vistas editan la misma sesion, asi que clips, ruteo, canciones, colores y mezcla se mantienen sincronizados."],
];

const controlHighlights = [
  ["Saltos en vivo", "Dispara secciones inmediatamente, en la siguiente marca, despues de varios compases o en limites de cancion con transiciones opcionales."],
  ["Warp y transposicion", "Cambia tempo o tonalidad por region de cancion mientras mantienes click, guias o referencias bajo control explicito."],
  ["Ruteo de escenario", "Usa pistas de audio, pistas de carpeta, ruteo heredado, metronomo, salidas hardware, MIDI Learn y control remoto movil."],
];

const fit = [
  ["Produccion", "Compone, graba, edita, mezcla y disena sonido en tu DAW de estudio.", "Trae el audio terminado a una sesion de playback enfocada en directo."],
  ["Preparacion del repertorio", "Un DAW general puede hacerlo, pero suele depender de escenas, acciones o plantillas de ruteo personalizadas.", "Construye canciones, marcas, clips, ruteo, paquetes y controles en vivo alrededor del repertorio."],
  ["Decisiones en vivo", "Flexible, pero normalmente atado a la complejidad de una sesion de produccion.", "Usa controles dedicados para Vamp, saltos, transiciones, transposicion, ruteo, MIDI y mezcla remota."],
  ["Superficie de escenario", "Potente para operadores que necesitan todo el entorno de produccion.", "Enfocado para musicos, directores musicales y operadores de playback que ejecutan directos preparados."],
];
---

<SiteLayout title="LibreTracks - Playback en Vivo Por Canciones" description="LibreTracks es una herramienta de playback en vivo por canciones para musicos, directores musicales y operadores de playback." lang="es">
  <main>
    <section class="site-shell hero">
      <div class="hero-grid">
        <div>
          <p class="eyebrow">Playback en vivo por canciones</p>
          <h1>LibreTracks</h1>
          <p>Prepara un concierto como canciones, pistas, marcas, cues y rutas. Organizalo en un timeline, ensayalo en Vista Compacta y ejecuta el directo con saltos musicales, control de tono, MIDI y control remoto movil.</p>
          <div class="hero-actions">
            <a class="button-link primary" href="/es/download">Descargar</a>
            <a class="button-link" href="/es/docs/">Explorar docs</a>
          </div>
        </div>
        <div class="product-shot">
          <img src="/screenshots/Compact-View.png" alt="Vista Compacta de LibreTracks con columnas de canciones y controles de mezcla" />
        </div>
      </div>
    </section>

    <section class="band">
      <div class="site-shell">
        <div class="section-heading">
          <p class="eyebrow">Para que sirve</p>
          <h2>Un lugar enfocado para convertir audio preparado en un directo controlado.</h2>
          <p>LibreTracks no intenta reemplazar tu DAW de produccion. Es una herramienta de escenario que toma pistas terminadas, las organiza por canciones y da al operador controles predecibles para ensayo y directo.</p>
        </div>
        <div class="feature-grid">
          {capabilities.map(([title, body]) => (
            <article class="feature-card">
              <strong>{title}</strong>
              <p>{body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="band">
      <div class="site-shell">
        <div class="section-heading">
          <p class="eyebrow">Flujo</p>
          <h2>De pistas preparadas a un repertorio listo para tocar.</h2>
        </div>
        <div class="workflow-grid">
          {workflow.map(([title, body, image]) => (
            <article class="workflow-card">
              <img src={image} alt={`${title} en LibreTracks`} loading="lazy" />
              <div>
                <strong>{title}</strong>
                <p>{body}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="band">
      <div class="site-shell docs-preview">
        <div class="section-heading">
          <p class="eyebrow">Dos vistas, un directo</p>
          <h2>Prepara en el timeline. Toca desde la lista de canciones.</h2>
          <p>El timeline lineal es ideal para construir la sesion; la Vista Compacta es ideal para ensayar canciones, disparar transiciones y mantener visible el mezclador. Las dos son proyecciones del mismo proyecto.</p>
          <div class="hero-actions">
            <a class="button-link primary" href="/es/docs/compact-view/">Docs Vista Compacta</a>
            <a class="button-link" href="/es/docs/core-concepts/">Conceptos base</a>
          </div>
        </div>
        <div class="docs-list">
          {viewHighlights.map(([title, body]) => (
            <article>
              <strong>{title}</strong>
              <p>{body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="band">
      <div class="site-shell">
        <div class="section-heading">
          <p class="eyebrow">Control en vivo</p>
          <h2>Haz flexible el directo sin convertirlo en una sesion de produccion.</h2>
          <p>LibreTracks mantiene las operaciones de escenario cerca de la intencion musical: saltar a secciones, sostener un Vamp, moverse entre canciones, transponer el repertorio, enviar cues y delegar mezcla a otro dispositivo.</p>
        </div>
        <div class="feature-grid">
          {controlHighlights.map(([title, body]) => (
            <article class="feature-card">
              <strong>{title}</strong>
              <p>{body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="band">
      <div class="site-shell">
        <div class="section-heading">
          <p class="eyebrow">Donde encaja</p>
          <h2>Usa tu DAW para producir. Usa LibreTracks para el concierto.</h2>
          <p>LibreTracks complementa herramientas como Reaper, Ableton Live, Logic o Cubase llevando audio preparado a un flujo dedicado de playback en directo.</p>
        </div>
        <table class="compare-table">
          <thead>
            <tr><th>Necesidad</th><th>DAW de estudio</th><th>LibreTracks</th></tr>
          </thead>
          <tbody>
            {fit.map(([need, daw, libretracks]) => (
              <tr><td>{need}</td><td>{daw}</td><td>{libretracks}</td></tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  </main>
</SiteLayout>
