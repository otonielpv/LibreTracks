---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  lang?: "en" | "es";
}

const { title, description, lang = "en" } = Astro.props;
const isSpanish = lang === "es";
const prefix = isSpanish ? "/es" : "";

// Language switch should stay on the equivalent page in the other language
// (e.g. /download ↔ /es/download), not jump back to the home page. Strip or
// add the `/es` prefix on the current path to build the counterpart URL.
const currentPath = Astro.url.pathname;
let switchHref: string;
if (isSpanish) {
  // /es/download → /download ; /es or /es/ → /
  switchHref = currentPath.replace(/^\/es(?=\/|$)/, "") || "/";
} else {
  // /download → /es/download ; / → /es/
  switchHref = currentPath === "/" ? "/es/" : `/es${currentPath}`;
}
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href="/icon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <div class="site-page">
      <header class="site-shell site-nav">
        <a class="brand" href={prefix || "/"}>
          <img src="/icon.svg" alt="" />
          <span>LibreTracks</span>
        </a>
        <nav class="nav-links" aria-label={isSpanish ? "Navegacion principal" : "Primary navigation"}>
          <a href={`${prefix}/download`}>{isSpanish ? "Descargas" : "Downloads"}</a>
          <a href={`${prefix}/docs/`}>{isSpanish ? "Documentacion" : "Docs"}</a>
          <a href={switchHref}>{isSpanish ? "English" : "Español"}</a>
          <a
            class="social-link"
            href="https://github.com/otonielpv/LibreTracks"
            aria-label="GitHub"
          >
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path
                fill="currentColor"
                d="M12 2C6.48 2 2 6.58 2 12.25c0 4.53 2.87 8.37 6.84 9.73.5.09.68-.22.68-.49 0-.24-.01-1.05-.01-1.91-2.51.47-3.16-.63-3.36-1.2-.11-.29-.6-1.2-1.03-1.44-.35-.19-.85-.66-.01-.67.79-.01 1.35.74 1.54 1.05.9 1.55 2.34 1.11 2.91.85.09-.67.35-1.11.64-1.37-2.22-.26-4.55-1.14-4.55-5.07 0-1.12.39-2.04 1.03-2.76-.1-.26-.45-1.31.1-2.72 0 0 .84-.28 2.75 1.05A9.28 9.28 0 0 1 12 6.96c.85 0 1.71.12 2.51.34 1.91-1.33 2.75-1.05 2.75-1.05.55 1.41.2 2.46.1 2.72.64.72 1.03 1.63 1.03 2.76 0 3.94-2.34 4.81-4.57 5.07.36.32.68.94.68 1.9 0 1.37-.01 2.47-.01 2.81 0 .27.18.59.69.49A10.17 10.17 0 0 0 22 12.25C22 6.58 17.52 2 12 2Z"
              />
            </svg>
          </a>
          <a
            class="social-link"
            href="https://www.facebook.com/groups/1795788251804551"
            aria-label={isSpanish ? "Grupo de Facebook" : "Facebook group"}
          >
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path
                fill="currentColor"
                d="M22 12.06C22 6.5 17.52 2 12 2S2 6.5 2 12.06c0 5.02 3.66 9.18 8.44 9.94v-7.03H7.9v-2.91h2.54V9.84c0-2.52 1.49-3.91 3.77-3.91 1.09 0 2.23.2 2.23.2v2.47h-1.26c-1.24 0-1.63.78-1.63 1.57v1.89h2.77l-.44 2.91h-2.33V22A10.04 10.04 0 0 0 22 12.06Z"
              />
            </svg>
          </a>
        </nav>
      </header>
      <slot />
    </div>
  </body>
</html>
