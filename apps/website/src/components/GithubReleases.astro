---
import { marked } from "marked";

interface Props {
  owner?: string;
  repo?: string;
  lang?: "en" | "es";
}

type ReleaseAsset = {
  name: string;
  browser_download_url: string;
  size: number;
};

type Release = {
  tag_name: string;
  published_at: string | null;
  html_url: string;
  body: string | null;
  assets: ReleaseAsset[];
};

const { owner = "otonielpv", repo = "LibreTracks", lang = "en" } = Astro.props;
const isSpanish = lang === "es";

// Release bodies ship both the Spanish ("## Novedades de vX") and English
// ("## What's New in vX") sections. Show only the one matching the current
// page language so the panel isn't twice as tall as it needs to be. Mirrors
// `extractReleaseNotesForLanguage` in apps/desktop/src/shared/updateCheck.ts.
const SECTION_HEADINGS: Record<"es" | "en", RegExp[]> = {
  es: [/^#{1,3}\s*Novedades(?:\s+de)?\s+v?\d+\.\d+\.\d+/i, /^#{1,3}\s*Novedades/i, /^#{1,3}\s*Cambios/i],
  en: [/^#{1,3}\s*What['’]s\s+New\s+in\s+v?\d+\.\d+\.\d+/i, /^#{1,3}\s*What['’]s\s+New/i, /^#{1,3}\s*Changes/i, /^#{1,3}\s*Release\s+Notes/i],
};
const ANY_HEADING = /^#{1,3}\s+/;

function extractReleaseNotesForLanguage(body: string, language: "es" | "en"): string {
  if (!body) return "";
  const lines = body.split(/\r?\n/);
  const patterns = SECTION_HEADINGS[language];

  let startIndex = -1;
  for (let i = 0; i < lines.length; i += 1) {
    if (patterns.some((pattern) => pattern.test(lines[i]))) {
      startIndex = i;
      break;
    }
  }
  if (startIndex === -1) return body.trim();

  const collected: string[] = [lines[startIndex]];
  for (let i = startIndex + 1; i < lines.length; i += 1) {
    if (ANY_HEADING.test(lines[i])) break;
    collected.push(lines[i]);
  }
  return collected.join("\n").trim();
}
const apiUrl = `https://api.github.com/repos/${owner}/${repo}/releases/latest`;

let release: Release | null = null;
let error: string | null = null;

try {
  const headers: HeadersInit = { Accept: "application/vnd.github+json" };
  // Añadimos el token si lo configuramos en Cloudflare
  if (import.meta.env.GITHUB_TOKEN) {
    headers["Authorization"] = `Bearer ${import.meta.env.GITHUB_TOKEN}`;
  }

  const response = await fetch(apiUrl, { headers });
  if (!response.ok) {
    throw new Error(`GitHub returned ${response.status}`);
  }
  release = await response.json();
} catch (caught) {
  error = caught instanceof Error ? caught.message : "Unknown error";
}

const labels = {
  currentVersion: isSpanish ? "Version actual" : "Current version",
  published: isSpanish ? "Publicado" : "Published",
  assets: isSpanish ? "Instaladores" : "Installers",
  notes: isSpanish ? "Notas de la version" : "Release notes",
  supportTitle: isSpanish ? "Apoya LibreTracks" : "Support LibreTracks",
  supportText: isSpanish
    ? "LibreTracks es gratuito. Las donaciones voluntarias ayudan con mantenimiento, pruebas, documentacion, releases y desarrollo continuo."
    : "LibreTracks is free. Voluntary donations help with maintenance, testing, documentation, releases, and ongoing development.",
  supportDisclaimer: isSpanish
    ? "La donacion no desbloquea funciones, soporte prioritario, acceso anticipado ni compromisos de desarrollo."
    : "Donations do not unlock features, priority support, early access, or development commitments.",
  supportAction: isSpanish ? "☕ Apoyar en Ko-fi" : "☕ Support on Ko-fi",
  downloadThanks: isSpanish ? "Gracias por descargar LibreTracks." : "Thanks for downloading LibreTracks.",
  downloadSupportText: isSpanish
    ? "Si el proyecto te resulta util, puedes apoyarlo con una donacion voluntaria en Ko-fi."
    : "If the project is useful to you, you can support it with a voluntary donation on Ko-fi.",
  downloadClose: isSpanish ? "Ahora no, gracias" : "Not now, thanks",
  fallback: isSpanish
    ? "No se pudo cargar la ultima release durante el build. Puedes abrir GitHub Releases directamente."
    : "The latest release could not be loaded during the build. You can open GitHub Releases directly.",
  noAssets: isSpanish ? "Esta release no contiene instaladores publicados." : "This release has no published installers.",
  open: isSpanish ? "Abrir en GitHub" : "Open on GitHub",
};

const releaseUrl = `https://github.com/${owner}/${repo}/releases/latest`;
const donationUrl = "https://ko-fi.com/otonielpv";
const date = release?.published_at
  ? new Intl.DateTimeFormat(isSpanish ? "es" : "en", { dateStyle: "medium" }).format(new Date(release.published_at))
  : null;

const localizedBody = release?.body
  ? extractReleaseNotesForLanguage(release.body, isSpanish ? "es" : "en")
  : "";
const bodyHtml = localizedBody ? await marked.parse(localizedBody) : null;

function iconForAsset(name: string): string {
  if (/\.msi$|\.exe$/i.test(name)) return "🪟";
  if (/\.dmg$/i.test(name)) return "🍎";
  if (/\.deb$|\.AppImage$|\.rpm$/i.test(name)) return "🐧";
  return "📦";
}
---

<section class="download-panel">
  {release ? (
    <>
      <div class="release-header">
        <p class="eyebrow">{labels.currentVersion}</p>
        <h1 class="release-version">{release.tag_name}</h1>
        {date ? <p class="release-date">{labels.published}: {date}</p> : null}
      </div>

      <div class="release-layout">
        {/* ── Assets column ── */}
        <div class="release-assets">
          <h3 class="release-section-title">{labels.assets}</h3>
          {release.assets.length > 0 ? (
            <div class="download-list">
              {release.assets.map((asset) => (
                <a class="download-card" href={asset.browser_download_url} target="_blank" rel="noopener noreferrer" data-download-asset>
                  <span class="download-icon">{iconForAsset(asset.name)}</span>
                  <span class="download-info">
                    <strong>{asset.name}</strong>
                    <span class="download-size">{Math.max(1, Math.round(asset.size / 1024 / 1024))} MB</span>
                  </span>
                  <span class="download-arrow">↓</span>
                </a>
              ))}
            </div>
          ) : <p>{labels.noAssets}</p>}
          <div class="hero-actions" style="margin-top: 1.25rem;">
            <a class="button-link" href={release.html_url}>{labels.open}</a>
          </div>
          <aside class="support-panel" aria-labelledby="support-title">
            <h3 id="support-title">{labels.supportTitle}</h3>
            <p>{labels.supportText}</p>
            <p class="support-disclaimer">{labels.supportDisclaimer}</p>
            <a class="button-link primary" href={donationUrl} target="_blank" rel="noreferrer">{labels.supportAction}</a>
          </aside>
        </div>

        {/* ── Release notes column ── */}
        {bodyHtml ? (
          <div class="release-notes-panel">
            <h3 class="release-section-title">{labels.notes}</h3>
            {/* The scroll wrapper is positioned so the notes never grow the
                grid row past the downloads column; the body scrolls inside. */}
            <div class="release-notes-scroll">
              <div class="release-notes-body" set:html={bodyHtml} />
            </div>
          </div>
        ) : null}
      </div>
    </>
  ) : (
    <>
      <p>{labels.fallback}</p>
      <p style="color: #ffe2ab;">{error}</p>
      <div class="hero-actions">
        <a class="button-link primary" href={releaseUrl}>{labels.open}</a>
      </div>
    </>
  )}
</section>

<dialog class="donation-dialog" data-donation-dialog>
  <div class="donation-dialog-body">
    <h3>{labels.downloadThanks}</h3>
    <p>{labels.downloadSupportText}</p>
    <p class="support-disclaimer">{labels.supportDisclaimer}</p>
    <div class="donation-dialog-actions">
      <a class="button-link primary" href={donationUrl} target="_blank" rel="noreferrer" data-donation-close>{labels.supportAction}</a>
      <button type="button" class="button-link" data-donation-close>{labels.downloadClose}</button>
    </div>
  </div>
</dialog>

<script>
  const dialog = document.querySelector("[data-donation-dialog]");
  const downloadLinks = document.querySelectorAll("[data-download-asset]");
  const closeButtons = document.querySelectorAll("[data-donation-close]");

  function showDonationReminder() {
    if (!(dialog instanceof HTMLDialogElement) || dialog.open) return;
    dialog.showModal();
  }

  downloadLinks.forEach((link) => {
    link.addEventListener("click", (event) => {
      if (!(link instanceof HTMLAnchorElement)) return;
      if (event.defaultPrevented) return;
      // Modifier-clicks / middle-click open in a new tab — let the
      // browser handle them without intercepting.
      const mouseEvent = event as MouseEvent;
      if (mouseEvent.button !== 0 || mouseEvent.metaKey || mouseEvent.ctrlKey || mouseEvent.shiftKey || mouseEvent.altKey) return;

      // On desktop, following the download URL in the same tab can move the
      // page away before the modal paints. Keep LibreTracks open, show the
      // reminder here, and let the browser handle the GitHub asset separately.
      event.preventDefault();
      showDonationReminder();
      window.open(link.href, "_blank", "noopener,noreferrer");
    });
  });

  closeButtons.forEach((button) => {
    button.addEventListener("click", () => {
      if (dialog instanceof HTMLDialogElement) dialog.close();
    });
  });

  dialog?.addEventListener("click", (event) => {
    if (event.target === dialog) {
      dialog.close();
    }
  });
</script>
