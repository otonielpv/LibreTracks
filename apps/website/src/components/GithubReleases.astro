---
import { marked } from "marked";

interface Props {
  owner?: string;
  repo?: string;
  lang?: "en" | "es";
}

type ReleaseAsset = {
  name: string;
  browser_download_url: string;
  size: number;
};

type Release = {
  tag_name: string;
  published_at: string | null;
  html_url: string;
  body: string | null;
  assets: ReleaseAsset[];
};

const { owner = "otonielpv", repo = "LibreTracks", lang = "en" } = Astro.props;
const isSpanish = lang === "es";
const apiUrl = `https://api.github.com/repos/${owner}/${repo}/releases/latest`;

let release: Release | null = null;
let error: string | null = null;

try {
  const headers: HeadersInit = { Accept: "application/vnd.github+json" };
  // Añadimos el token si lo configuramos en Cloudflare
  if (import.meta.env.GITHUB_TOKEN) {
    headers["Authorization"] = `Bearer ${import.meta.env.GITHUB_TOKEN}`;
  }

  const response = await fetch(apiUrl, { headers });
  if (!response.ok) {
    throw new Error(`GitHub returned ${response.status}`);
  }
  release = await response.json();
} catch (caught) {
  error = caught instanceof Error ? caught.message : "Unknown error";
}

const labels = {
  currentVersion: isSpanish ? "Version actual" : "Current version",
  published: isSpanish ? "Publicado" : "Published",
  assets: isSpanish ? "Instaladores" : "Installers",
  notes: isSpanish ? "Notas de la version" : "Release notes",
  fallback: isSpanish
    ? "No se pudo cargar la ultima release durante el build. Puedes abrir GitHub Releases directamente."
    : "The latest release could not be loaded during the build. You can open GitHub Releases directly.",
  noAssets: isSpanish ? "Esta release no contiene instaladores publicados." : "This release has no published installers.",
  open: isSpanish ? "Abrir en GitHub" : "Open on GitHub",
};

const releaseUrl = `https://github.com/${owner}/${repo}/releases/latest`;
const date = release?.published_at
  ? new Intl.DateTimeFormat(isSpanish ? "es" : "en", { dateStyle: "medium" }).format(new Date(release.published_at))
  : null;

const bodyHtml = release?.body ? await marked.parse(release.body) : null;

function iconForAsset(name: string): string {
  if (/\.msi$|\.exe$/i.test(name)) return "🪟";
  if (/\.dmg$/i.test(name)) return "🍎";
  if (/\.deb$|\.AppImage$|\.rpm$/i.test(name)) return "🐧";
  return "📦";
}
---

<section class="download-panel">
  {release ? (
    <>
      <div class="release-header">
        <p class="eyebrow">{labels.currentVersion}</p>
        <h1 class="release-version">{release.tag_name}</h1>
        {date ? <p class="release-date">{labels.published}: {date}</p> : null}
      </div>

      <div class="release-layout">
        {/* ── Assets column ── */}
        <div class="release-assets">
          <h3 class="release-section-title">{labels.assets}</h3>
          {release.assets.length > 0 ? (
            <div class="download-list">
              {release.assets.map((asset) => (
                <a class="download-card" href={asset.browser_download_url}>
                  <span class="download-icon">{iconForAsset(asset.name)}</span>
                  <span class="download-info">
                    <strong>{asset.name}</strong>
                    <span class="download-size">{Math.max(1, Math.round(asset.size / 1024 / 1024))} MB</span>
                  </span>
                  <span class="download-arrow">↓</span>
                </a>
              ))}
            </div>
          ) : <p>{labels.noAssets}</p>}
          <div class="hero-actions" style="margin-top: 1.25rem;">
            <a class="button-link" href={release.html_url}>{labels.open}</a>
          </div>
        </div>

        {/* ── Release notes column ── */}
        {bodyHtml ? (
          <div class="release-notes-panel">
            <h3 class="release-section-title">{labels.notes}</h3>
            <div class="release-notes-body" set:html={bodyHtml} />
          </div>
        ) : null}
      </div>
    </>
  ) : (
    <>
      <p>{labels.fallback}</p>
      <p style="color: #ffe2ab;">{error}</p>
      <div class="hero-actions">
        <a class="button-link primary" href={releaseUrl}>{labels.open}</a>
      </div>
    </>
  )}
</section>
