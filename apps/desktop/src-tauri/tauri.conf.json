{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LibreTracks",
  "version": "0.0.1",
  "identifier": "com.libretracks.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420",
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1 --port 1420 --strictPort",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "LibreTracks",
        "width": 1440,
        "height": 900,
        "maximized": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
