{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LibreTracks",
  "version": "0.0.9",
  "identifier": "com.libretracks.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420",
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1 --port 1420 --strictPort",
    "beforeBuildCommand": "npm --prefix ../../ run build:remote && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "LibreTracks",
        "width": 1440,
        "height": 900,
        "maximized": true,
        "dragDropEnabled": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "deb", "appimage", "app", "dmg"],
    "resources": {
      "../../remote/dist": "remote-dist",
      "../../../vendor/bin/native/*": "."
    },
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    },
    "macOS": {
      "frameworks": [
        "../../../vendor/bin/native/liblt_audio_engine_v2.dylib",
        "../../../vendor/bin/native/bungee.framework"
      ]
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
