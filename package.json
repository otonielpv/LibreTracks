{
  "name": "libretracks",
  "private": true,
  "version": "0.0.1",
  "description": "Editor y reproductor multitrack con escritorio Tauri y control remoto web.",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:desktop": "npm --workspace apps/desktop run dev",
    "dev:remote": "npm --workspace apps/remote run dev",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "engines": {
    "node": ">=20"
  }
}
