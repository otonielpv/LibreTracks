{
  "name": "libretracks",
  "private": true,
  "version": "1.5.0",
  "license": "AGPL-3.0-or-later",
  "description": "Editor y reproductor multitrack con escritorio Tauri y control remoto web.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:desktop": "npm --prefix apps/desktop run dev --",
    "dev:desktop:native": "node ./scripts/desktop-native.mjs dev",
    "dev:desktop:engine-v2": "node ./scripts/desktop-native.mjs dev",
    "build:desktop": "npm --prefix apps/desktop run build",
    "check:desktop:native": "node ./scripts/desktop-native.mjs check",
    "build:desktop:native": "node ./scripts/desktop-native.mjs build",
    "test:desktop": "npm --prefix apps/desktop run test",
    "test:shared": "npm --prefix packages/shared run test",
    "dev:remote": "npm --prefix apps/remote run dev --",
    "build:remote": "npm --prefix apps/remote run build",
    "test:remote": "npm --prefix apps/remote run test",
    "dev:website": "npm --prefix apps/website run dev --",
    "build:website": "npm --prefix apps/website run build",
    "test": "node ./scripts/test-all.mjs",
    "test:full": "node ./scripts/test-full.mjs",
    "test:native": "node ./scripts/desktop-native.mjs test",
    "test:native:nolink": "cargo test -p libretracks-desktop -p lt-audio-engine-v2 --features libretracks-desktop/no-link",
    "lint": "npm --prefix apps/desktop run lint && npm --prefix apps/remote run lint && npm --prefix packages/shared run lint"
  },
  "engines": {
    "node": ">=20"
  }
}
