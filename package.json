{
  "name": "libretracks",
  "private": true,
  "version": "0.0.1",
  "description": "Editor y reproductor multitrack con escritorio Tauri y control remoto web.",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:desktop": "npm --prefix apps/desktop run dev --",
    "build:desktop": "npm --prefix apps/desktop run build",
    "test:desktop": "npm --prefix apps/desktop run test",
    "dev:remote": "npm --prefix apps/remote run dev --",
    "build:remote": "npm --prefix apps/remote run build",
    "test:remote": "npm --prefix apps/remote run test",
    "test": "npm run test:desktop",
    "lint": "npm --prefix apps/desktop run lint && npm --prefix apps/remote run lint"
  },
  "engines": {
    "node": ">=20"
  }
}
