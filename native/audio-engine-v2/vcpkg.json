{
  "name": "libretracks-audio-engine-v2",
  "version-string": "0.1.0",
  "dependencies": [
    {
      "name": "ffmpeg",
      "default-features": false,
      "features": [
        "avcodec",
        "avformat",
        "swresample"
      ]
    }
  ],
  "features": {
    "rubberband": {
      "description": "Optional RubberBand fallback/debug warp backend.",
      "dependencies": [
        "rubberband"
      ]
    }
  }
}
