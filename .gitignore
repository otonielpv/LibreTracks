node_modules/
dist/
coverage/
.turbo/
.astro/

target/
target-desktop-native/
target-desktop-check/
vendor/bin/native/*
!vendor/bin/native/.gitkeep
# Bungee pitch SDK — downloaded per-machine, not vendored (see README "Bungee pitch backend")
vendor/bungee/
# FFmpeg built/relocated per-machine by scripts/build-ffmpeg-universal.sh — regenerated, not vendored
vendor/.ffmpeg-build/
vendor/ffmpeg-universal/
# Same, for the Linux build (scripts/build-ffmpeg-linux.sh)
vendor/.ffmpeg-build-linux/
vendor/ffmpeg-linux/

*.log
.DS_Store
Thumbs.db
repomix-output.xml
graphify-out/
.claude/settings.local.json
native/audio-engine-v2/build*
native/audio-engine-v2/vcpkg_installed/
build-rb-tests*
build-rb-release*
build*
# ...but the FFmpeg build *scripts* are source, not build artifacts (the broad build* above would catch them).
!scripts/build-ffmpeg-universal.sh
!scripts/build-ffmpeg-linux.sh
# ...and the Android gradle project files are source too. Without these
# negations a fresh clone can't build the Android app at all (the gradle
# build scripts were silently swallowed by `build*`). gen/android/.gitignore
# still excludes the actual build outputs (app/build, .gradle, buildSrc/build).
!apps/desktop/src-tauri/gen/android/build.gradle.kts
!apps/desktop/src-tauri/gen/android/app/build.gradle.kts
!apps/desktop/src-tauri/gen/android/app/tauri.build.gradle.kts
!apps/desktop/src-tauri/gen/android/buildSrc/
!apps/desktop/src-tauri/gen/android/buildSrc/build.gradle.kts
apps/desktop/src-tauri/gen/android/buildSrc/build/
bench-out*
.graphify_detect_fast.json
.graphify_detect.json
.claude/scheduled_tasks.lock
